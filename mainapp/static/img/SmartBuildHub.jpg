<body class="animated-gradient bg-gradient-to-r from-gray-600 via-gray-700 to-gray-900">

  <!-- Navbar -->
  <header class="h-20 w-full animated-gradient bg-gradient-to-r from-gray-900 via-gray-900 to-gray-900">
    <nav id="mainNav" x-data="{ isOpen: false }" class="fixed w-full z-100 transition-all duration-300 nav-transparent" style="height: 80px;">
      <div class="max-w-7xl mx-auto px-6 sm:px-0 lg:px-0">
        <div class="flex items-center justify-between h-20">
          <!-- Logo section -->
          <div class="flex-shrink-0 flex items-center">
            <a href="https://softproproject.pythonanywhere.com/" class="flex items-center">
              <!-- Logo with hover animation -->
              <img class="h-16 logo" src="./SmartBuildHub_files/smartbuild_Logo_dark.png" alt="Logo">
            </a>
          </div>

          <!-- Navigation links - hidden on mobile -->
          <div class="hidden md:block">
            <div class="ml-10 flex items-center space-x-6">
              <a href="https://softproproject.pythonanywhere.com/" class="nav-link text-white px-3 py-2 rounded-md text-sm font-medium transition-all duration-300">Home</a>
              <a href="https://softproproject.pythonanywhere.com/services/" class="nav-link text-white px-3 py-2 rounded-md text-sm font-medium transition-all duration-300">Services</a>
              <a href="https://softproproject.pythonanywhere.com/project/" class="nav-link text-white px-3 py-2 rounded-md text-sm font-medium transition-all duration-300">Projects</a>
              <a href="https://softproproject.pythonanywhere.com/about/" class="nav-link text-white px-3 py-2 rounded-md text-sm font-medium transition-all duration-300">About</a>
              <a href="https://softproproject.pythonanywhere.com/contact/" class="nav-link text-white px-3 py-2 rounded-md text-sm font-medium transition-all duration-300">Contact</a>
            </div>
          </div>

          <!-- Right side profile section with dropdown -->
          <!-- Right side profile section with dropdown (no icon) -->
          
          <!-- Sign In Button -->
          <div class="pt-4 pb-3 border-gray-700">
            <div class="flex items-center px-3">
              <a href="https://softproproject.pythonanywhere.com/auth/" class="block px-4 py-2 text-base font-medium text-white bg-orange-400 hover:bg-orange-500 rounded-md w-full text-center transition-all duration-300">Sign In</a>
            </div>
          </div>
          

          <!-- Mobile menu button with animation -->
          <div class="flex md:hidden">
            <button @click="isOpen = !isOpen" type="button" class="inline-flex items-center justify-center p-2 rounded-md text-gray-200 hover:bg-gray-700 focus:outline-none transition-all duration-300">
              <svg :class="{&#39;hidden&#39;: isOpen, &#39;block&#39;: !isOpen }" class="h-6 w-6 block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <svg :class="{&#39;block&#39;: isOpen, &#39;hidden&#39;: !isOpen }" class="h-6 w-6 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile menu with animation -->
      <div x-show="isOpen" x-transition:enter="mobile-menu-enter" x-transition:enter-start="mobile-menu-enter" x-transition:enter-end="mobile-menu-enter-active" x-transition:leave="mobile-menu-exit" x-transition:leave-start="mobile-menu-exit" x-transition:leave-end="mobile-menu-exit-active" class="md:hidden mobile-menu-bg" style="display: none;">
        <div class="px-2 pt-2 pb-3 space-y-1">
          <a href="https://softproproject.pythonanywhere.com/" class="block px-3 py-2 rounded-md text-base font-medium text-white hover:bg-orange-400 transition-all duration-300">Home</a>
          <a href="https://softproproject.pythonanywhere.com/services/" class="block px-3 py-2 rounded-md text-base font-medium text-white hover:bg-orange-400 transition-all duration-300">Services</a>
          <a href="https://softproproject.pythonanywhere.com/projects/" class="block px-3 py-2 rounded-md text-base font-medium text-white hover:bg-orange-400 transition-all duration-300">Projects</a>
          <a href="https://softproproject.pythonanywhere.com/about/" class="block px-3 py-2 rounded-md text-base font-medium text-white hover:bg-orange-400 transition-all duration-300">About</a>
          <a href="https://softproproject.pythonanywhere.com/contact/" class="block px-3 py-2 rounded-md text-base font-medium text-white hover:bg-orange-400 transition-all duration-300">Contact</a>
          <div class="pt-4 pb-3 border-t border-gray-700">
            <div class="flex items-center px-3">
              <a href="https://softproproject.pythonanywhere.com/auth/" class="block px-4 py-2 text-base font-medium text-white bg-orange-400 hover:bg-orange-500 rounded-md w-full text-center transition-all duration-300">Sign In</a>
            </div>
          </div>
        </div>
      </div>
    </nav>

  </header>

  <main class="min-h-screen">
    
<!-- Hero Section -->
<section class="bg-gradient-to-br from-orange-500 to-orange-700 text-white py-24 relative overflow-hidden hero-pattern">
    <div class="absolute inset-0 bg-black opacity-50"></div>
    <div class="max-w-6xl mx-auto px-4 relative z-10">
        <div class="flex flex-col items-center text-center">
            <h1 class="text-5xl text-orange-500 md:text-6xl font-bold mb-6 fade-in-up observed visible">About SmartBuildHub</h1>
            <div class="w-20 h-1 bg-white mb-8 fade-in delay-200 observed visible"></div>
            <p class="text-xl max-w-3xl fade-in-up delay-300 observed visible">Revolutionizing the construction industry with innovative smart building solutions and sustainable practices.</p>
        </div>
    </div>
</section>

<!-- Mission Section -->
<section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
        <div class="flex flex-col items-center mb-16">
            <span class="text-orange-500 font-semibold mb-2 fade-in-up observed visible">WHO WE ARE</span>
            <h2 class="text-3xl md:text-4xl font-bold text-center mb-6 fade-in-up delay-100 observed visible">Our Mission</h2>
            <div class="w-16 h-1 bg-orange-500 mb-10 fade-in delay-200 observed visible"></div>
            <p class="text-lg text-gray-600 max-w-3xl mx-auto text-center fade-in-up delay-300 observed visible">
                At SmartBuildHub, we're committed to transforming the future of construction through cutting-edge technology, sustainable practices, and unparalleled expertise. We believe in creating buildings that are not just structures, but intelligent ecosystems that enhance lives.
            </p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="stat-card bg-orange-50 p-8 rounded-lg text-center scale-in delay-100 observed visible">
                <div class="text-4xl font-bold text-orange-600 mb-2 counter" data-original-text="250+" data-target="250">250+</div>
                <div class="text-gray-700 font-medium">Projects Completed</div>
            </div>
            <div class="stat-card bg-orange-50 p-8 rounded-lg text-center scale-in delay-200 observed visible">
                <div class="text-4xl font-bold text-orange-600 mb-2 counter" data-original-text="30+" data-target="30">30+</div>
                <div class="text-gray-700 font-medium">Years Experience</div>
            </div>
            <div class="stat-card bg-orange-50 p-8 rounded-lg text-center scale-in delay-300 observed visible">
