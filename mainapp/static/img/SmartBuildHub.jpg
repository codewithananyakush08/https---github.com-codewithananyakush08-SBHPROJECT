<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Intersection Observer for animations
        const observerOptions = {
            root: null,
            rootMargin: '0px',
            threshold: 0.1
        };
        
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    // Add the visible class which will trigger the animation
                    entry.target.classList.add('visible');
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);
        
        // Observe all elements with animation classes
        document.querySelectorAll('.fade-in-up, .fade-in, .scale-in').forEach(el => {
            observer.observe(el);
            // Add a class that will control when the animation plays
            el.classList.add('observed');
        });
        
        // Counter animation for statistics
        const counters = document.querySelectorAll('.counter');
        
        counters.forEach(counter => {
            const updateCount = () => {
                // Extract the original text to preserve symbols
                const originalText = counter.getAttribute('data-original-text');
                
                // Determine if there are any symbols we need to preserve
                const hasPlus = originalText.includes('+');
                const hasPercent = originalText.includes('%');
                
                // Extract just the numeric value from the target
                const target = counter.getAttribute('data-target');
                
                // Get current count (removing any non-numeric characters)
                const count = +counter.innerText.replace(/[^\d.-]/g, '') || 0;
                
                const speed = 1000; // Animation speed in milliseconds
                const inc = target / speed * 10;
                
                if (count < target) {
                    let newValue = Math.ceil(count + inc);
                    
                    // Add back the appropriate symbols
                    if (hasPlus) {
                        counter.innerText = newValue + '+';
                    } else if (hasPercent) {
                        counter.innerText = newValue + '%';
                    } else {
                        counter.innerText = newValue;
                    }
                    
                    setTimeout(updateCount, 10);
                } else {
                    // Ensure we end with the exact original text
                    counter.innerText = originalText;
                }
            };
            
            // Start the counter animation when element is in view
            const statObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        // Store the original text including any symbols
                        const originalText = counter.innerText;
                        counter.setAttribute('data-original-text', originalText);
                        
                        // Extract just the numeric value
                        const numericValue = parseInt(originalText.replace(/[^\d.-]/g, ''));
                        counter.setAttribute('data-target', numericValue);
                        
                        // Start from zero
                        counter.innerText = '0';
                        updateCount();
                        statObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.5 });
            
            statObserver.observe(counter);
        });
    });
</script>

